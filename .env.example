# EduCheck AI — optional default AI keys.
# Users can also paste keys at runtime via the in-app Settings modal (stored in localStorage).
# Copy to ".env.local" and fill in to ship a demo with live AI pre-connected.
#
# ⚠️ These are exposed to the browser (VITE_ prefix). For production, proxy AI
#    calls through a serverless/edge function instead of shipping keys client-side.

VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
